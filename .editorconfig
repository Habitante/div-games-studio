# DIV Games Studio - Editor Configuration
# https://editorconfig.org

root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false

[*.{c,h,hpp,cpp}]
indent_size = 2

[Makefile*]
indent_style = tab

[*.sh]
indent_size = 2

# Binary/data files - no processing
[*.{div,fon,fpg,map,pal,prg,bin,fli,exe,dll}]
charset = unset
end_of_line = unset
trim_trailing_whitespace = unset
insert_final_newline = unset
